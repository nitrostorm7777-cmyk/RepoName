local HttpService = game:GetService("HttpService")
local CoreGui = game:GetService("CoreGui")

-- [[ CONFIGURATION ]] --
local CurrentVersion = "1.0" 
-- 1. MAKE SURE THIS MATCHES YOUR FILE NAME ON GITHUB
local VersionSource = "https://raw.githubusercontent.com/nitrostorm7777-cmyk/RepoName/main/test"

local function GetLatestVersion()
    -- Adding a random string to the URL to bypass all caching
    local cacheBuster = "?nocache=" .. game:GetService("HttpService"):GenerateGUID(false)
    local success, result = pcall(function()
        return game:HttpGet(VersionSource .. cacheBuster)
    end)
    
    if success then
        -- This regex ([^%d%.]) deletes EVERYTHING that isn't a number or a dot
        -- It removes spaces, "Enter" keys, and invisible GitHub metadata
        local cleaned = result:gsub("[^%d%.]", "") 
        return cleaned
    end
    return "OFFLINE"
end

local Latest = GetLatestVersion()

-- [[ UI SYSTEM ]] --
if CoreGui:FindFirstChild("Nexus_Auth") then CoreGui.Nexus_Auth:Destroy() end
local ScreenGui = Instance.new("ScreenGui", CoreGui); ScreenGui.Name = "Nexus_Auth"
