local Debug = Instance.new("TextLabel", Main)
Debug.Size = UDim2.new(1, 0, 0, 20); Debug.Position = UDim2.new(0, 0, 1, -20); Debug.BackgroundTransparency = 1; Debug.Font = Enum.Font.Code; Debug.TextSize = 11; Debug.TextColor3 = Color3.fromRGB(100, 100, 100)
Debug.Text = "COMPARING: [" .. CurrentVersion .. "] vs [" .. tostring(Latest) .. "]"

-- [[ VALIDATION ]] --
if Latest == CurrentVersion then
    Stroke.Color = Color3.fromRGB(0, 255, 255)
    Title.Text = "ACCESS GRANTED"
    Title.TextColor3 = Color3.fromRGB(0, 255, 255)
    task.delay(1.5, function() ScreenGui:Destroy() end)
