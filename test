local HttpService = game:GetService("HttpService")
local CoreGui = game:GetService("CoreGui")

-- [[ CONFIGURATION ]] --
local CurrentVersion = "2.0" 
local VersionSource = "https://raw.githubusercontent.com/nitrostorm7777-cmyk/RepoName/main/test"

local function GetLatestVersion()
    -- Bypass cache
    local cacheBuster = "?t=" .. tick()
    local success, result = pcall(function()
        return game:HttpGet(VersionSource .. cacheBuster)
    end)
    
    if success then
        -- This specific pattern [%d%.]+ finds ONLY numbers and dots
        -- It ignores EVERYTHING else (spaces, enters, hidden symbols)
        local cleaned = result:match("[%d%.]+") 
        
        if cleaned then
            return cleaned
        else
            -- If no numbers were found, return the raw result for debugging
            return result:sub(1, 10):gsub("%s+", "_") 
        end
    end
    return "OFFLINE"
end

local Latest = GetLatestVersion()

