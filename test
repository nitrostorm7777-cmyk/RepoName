local Info = Instance.new("TextLabel", Main)
Info.Size = UDim2.new(0.9, 0, 0, 40); Info.Position = UDim2.new(0.05, 0, 0.35, 0); Info.BackgroundTransparency = 1; Info.Font = Enum.Font.Gotham; Info.TextSize = 14; Info.TextColor3 = Color3.fromRGB(180, 180, 180)

-- [[ FINAL COMPARISON LOGIC ]] --
if Latest == CurrentVersion:lower() then
    -- MATCH FOUND
    Stroke.Color = Color3.fromRGB(0, 255, 150)
