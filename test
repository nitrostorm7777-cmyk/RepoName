local HttpService = game:GetService("HttpService")
local CoreGui = game:GetService("CoreGui")

-- [[ CONFIGURATION ]] --
local CurrentVersion = "1.0" 
-- Using the direct raw path for better compatibility
local VersionSource = "https://raw.githubusercontent.com/nitrostorm7777-cmyk/RepoName/main/test"

-- [[ THE "ULTRA-CLEAN" FETCH ]] --
local function GetLatestVersion()
    local cacheBuster = "?t=" .. tick()
    local success, result = pcall(function()
        return game:HttpGet(VersionSource .. cacheBuster)
    end)
    
    if success then
        -- This regex removes everything except letters, numbers, and dots
        local cleaned = result:gsub("[^%w%.]", "") 
        return cleaned:lower()
    end
    return "offline"
end

local Latest = GetLatestVersion()

-- [[ UI SYSTEM ]] --
